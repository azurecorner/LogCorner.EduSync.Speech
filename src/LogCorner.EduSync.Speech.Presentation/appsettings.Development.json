{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "System": "Information",
      "Microsoft": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log.txt",
          "outputTemplate": "{Timestamp} {Message}{NewLine:1}{Exception:1}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ],

    "Properties": {
      "ApplicationName": "LogCorner.EduSync.Speech.Command.Http.Api"
    }
  },
  // "HubUrl": "https://localhost:5001/logcornerhub",
  "allowedOrigins": "http://localhost:4200",
  "ConnectionStrings": {
    "SpeechDB": "Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=LogCorner.EduSync.Speech.Database;Integrated Security=True"
  },
  "pathBase": "/speech-command-http-api"
}