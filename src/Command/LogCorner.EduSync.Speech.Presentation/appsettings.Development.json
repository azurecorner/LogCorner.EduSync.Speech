{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "System": "Information",
      "Microsoft": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log.txt",
          "outputTemplate": "{Timestamp} {Message}{NewLine:1}{Exception:1}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ],

    "Properties": {
      "ApplicationName": "LogCorner.EduSync.Speech.Command.Http.Api"
    }
  },
  //"HubUrl": "https://localhost:8001/logcornerhub",
  "allowedOrigins": "http://localhost:4200",
  "ConnectionStrings": {
    //"SpeechDB": "Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=LogCorner.EduSync.Speech.Database;Integrated Security=True"
    "SpeechDB": "Server=tcp:sqlserver-datasynchro.database.windows.net,1433;Initial Catalog=LogCorner.EduSync.Speech.Database;Persist Security Info=False;User ID=logcorner;Password=MySecureP@ssword;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "UserAssignedClientId": "6b7ff166-a810-4d74-827c-05a90598e7e2", //// workload-managed-identity  client id
  "ServiceBusNamespace": "sb-namespace-datasynchro.servicebus.windows.net",
  "serviceBusQueueName": "sb-queue-datasynchro"
}