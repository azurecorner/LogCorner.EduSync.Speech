@model IEnumerable<LogCorner.EduSync.Speech.Presentation.Models.SpeechModel>
@inject IConfiguration Configuration
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Speech List</h1>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Create New
    </a>
</div>

<div id="speech-list" class="shadow-sm p-3 bg-white rounded">
    @await Html.PartialAsync("_SpeechListPartial", Model)
</div>

@section Scripts {
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.js"></script>
    <script>
        console.log("SignalR script loaded");

          console.log("HubUrl => @Configuration["HubUrl"]");

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("@Configuration["HubUrl"]?clientName=LogCorner.EduSync.Speech.Front") // your hub endpoint
            .build();

        // Listen to all published events
        connection.on("OnPublish", function(topic, header, payload) {
            console.log("OnPublish received:", topic, header, payload);

            // Only handle ReadModelAcknowledged
            if (topic === "ReadModelAcknowledged") {
                console.log("ReadModelAcknowledged event received, refreshing table...");

                // Refresh table via partial view
                fetch("/Speech/IndexPartial")
                    .then(r => r.text())
                    .then(html => {
                        document.getElementById("speech-list").innerHTML = html;
                    });
            }
        });

        connection.start()
            .then(() => console.log("SignalR connected, listening for ReadModelAcknowledged"))
            .catch(err => console.error(err.toString()));
    </script>
}
