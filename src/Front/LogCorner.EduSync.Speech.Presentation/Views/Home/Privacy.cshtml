@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container my-5">
    <h1 class="display-5 fw-bold mb-4">@ViewData["Title"]</h1>

    <p class="lead text-muted">
        This page provides detailed information about our site's privacy practices.
    </p>

    <section class="mt-4">
        <h4>Information We Collect</h4>
        <p>We may collect personal information such as name, email address, and usage data to improve your experience.</p>
    </section>

    <section class="mt-4">
        <h4>How We Use Information</h4>
        <p>Your data is used only for providing and improving our services. We never share your personal information without consent.</p>
    </section>

    <section class="mt-4">
        <h4>Contact</h4>
        <p>If you have questions about our privacy practices, please contact us at <a href="mailto:support@edusync.com">support@edusync.com</a>.</p>
    </section>
</div>
