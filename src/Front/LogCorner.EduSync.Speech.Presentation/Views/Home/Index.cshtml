@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center my-5">
    <h1 class="display-4 fw-bold mb-3">Welcome to EduSync Speech App</h1>
    <p class="lead text-muted">
        Manage speeches easily with ASP.NET Core MVC and Web API integration.
    </p>

    <div class="mt-4">
        <a asp-controller="Speech" asp-action="Index" class="btn btn-primary btn-lg me-2">
            <i class="bi bi-list-ul"></i> View Speeches
        </a>
        <a asp-controller="Speech" asp-action="Create" class="btn btn-success btn-lg">
            <i class="bi bi-plus-circle"></i> Create Speech
        </a>
    </div>

    <hr class="my-5" />

    <p>
        Learn more about
        <a href="https://learn.microsoft.com/aspnet/core" target="_blank" class="link-primary">
            building Web apps with ASP.NET Core
        </a>.
    </p>
</div>
